{
  "name": "test-react",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "npm run start:development",
    "start:development": "vite --mode development",
    "start:staging": "vite --mode staging",
    "start:production": "vite --mode production",
    "build": "npm run build:development",
    "build:development": "tsc && vite build --mode development",
    "build:staging": "tsc && vite build --mode staging",
    "build:production": "tsc && vite build --mode production",
    "preview": "vite preview",
    "lint": "tsc && eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" && eslint --fix \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "vitest"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.1",
    "axios": "^1.2.0",
    "bootstrap": "^5.2.2",
    "bootstrap-icons": "^1.10.2",
    "formik": "^2.2.9",
    "immer": "^9.0.16",
    "invariant": "^2.2.4",
    "lodash-es": "^4.17.21",
    "luxon": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^6.4.3",
    "react-select": "^5.7.0",
    "reactstrap": "^9.1.5",
    "redux": "^4.2.0",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/eslint": "^8.4.10",
    "@types/lodash-es": "^4.17.6",
    "@types/luxon": "^3.1.0",
    "@types/node": "^18.11.9",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.8",
    "@vitejs/plugin-react": "^2.2.0",
    "eslint": "^8.27.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-config-recommended": "^4.1.0",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "fs-extra": "^10.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^20.0.2",
    "prettier": "^2.7.1",
    "react-test-renderer": "^18.2.0",
    "sass": "^1.56.1",
    "stylelint": "^14.14.1",
    "stylelint-config-twbs-bootstrap": "^6.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.8.4",
    "vite": "^3.2.3",
    "vite-plugin-checker": "^0.5.1",
    "vite-plugin-pwa": "^0.13.3",
    "vite-plugin-stylelint": "^3.0.8",
    "vite-plugin-svgr": "^2.2.2",
    "vite-tsconfig-paths": "^3.5.2",
    "vitest": "^0.25.7",
    "workbox-window": "^6.5.4"
  }
}
